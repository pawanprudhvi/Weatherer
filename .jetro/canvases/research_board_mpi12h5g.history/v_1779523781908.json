      "data": {
        "title": "SkyFlow Weather Hub",
        "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>SkyFlow Weather Hub</title>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n<script src=\"https://cdn.plot.ly/plotly-2.26.0.min.js\"></script>\n<style>\n  :root {\n    --bg: #070b18;\n    --panel: rgba(13,19,42,0.8);\n    --border: rgba(255,255,255,0.07);\n    --border-hi: rgba(255,255,255,0.15);\n    --accent: #6366f1;\n    --accent2: #38bdf8;\n    --green: #22c55e;\n    --amber: #f59e0b;\n    --red: #ef4444;\n    --text: #f1f5f9;\n    --muted: #64748b;\n    --subtle: #94a3b8;\n    --r: 20px;\n  }\n  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}\n  html,body{width:100%;min-height:100%;background:var(--bg);color:var(--text);\n    font-family:'Inter',sans-serif;font-size:14px;-webkit-font-smoothing:antialiased;}\n  body{display:flex;flex-direction:column;gap:0;overflow-x:hidden;}\n\n  /* ── HEADER ── */\n  .hub-header{\n    background:linear-gradient(135deg,rgba(99,102,241,0.15) 0%,rgba(56,189,248,0.08) 100%);\n    border-bottom:1px solid var(--border);\n    padding:20px 24px 16px;\n    display:flex;flex-direction:column;gap:14px;\n  }\n  .hub-brand{display:flex;align-items:center;gap:10px;}\n  .hub-brand svg{width:28px;height:28px;color:var(--accent);}\n  .hub-brand h1{font-family:'Outfit',sans-serif;font-size:1.5rem;font-weight:800;\n    background:linear-gradient(135deg,#fff 40%,var(--accent) 100%);\n    -webkit-background-clip:text;-webkit-text-fill-color:transparent;}\n\n  /* ── SEARCH ROW ── */\n  .search-row{display:flex;gap:10px;flex-wrap:wrap;align-items:center;}\n  .search-box{\n    display:flex;align-items:center;flex:1;min-width:220px;max-width:480px;\n    background:rgba(255,255,255,0.04);border:1px solid var(--border);\n    border-radius:14px;padding:0 16px;height:44px;\n    transition:border-color .2s,box-shadow .2s;\n  }\n  .search-box:focus-within{border-color:var(--accent);box-shadow:0 0 0 3px rgba(99,102,241,.15);}\n  .search-box input{flex:1;background:transparent;border:none;outline:none;color:var(--text);\n    font-size:0.9rem;font-family:inherit;}\n  .search-box input::placeholder{color:var(--muted);}\n  .btn{\n    height:44px;padding:0 20px;border-radius:12px;font-weight:600;font-size:0.85rem;\n    border:none;cursor:pointer;display:flex;align-items:center;gap:7px;\n    transition:all .2s;white-space:nowrap;\n  }\n  .btn-primary{background:var(--accent);color:#fff;}\n  .btn-primary:hover{background:#4f46e5;transform:translateY(-1px);}\n  .btn-primary:active{transform:translateY(0);}\n  .btn-outline{background:rgba(255,255,255,0.04);border:1px solid var(--border);color:var(--subtle);}\n  .btn-outline:hover{border-color:var(--border-hi);color:#fff;}\n  .btn-danger{background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.25);color:var(--red);}\n  .btn-danger:hover{background:rgba(239,68,68,0.2);}\n\n  /* ── CITY TAGS ── */\n  .city-tags{display:flex;flex-wrap:wrap;gap:8px;}\n  .city-tag{\n    display:flex;align-items:center;gap:6px;padding:6px 12px;\n    background:rgba(99,102,241,0.1);border:1px solid rgba(99,102,241,0.25);\n    border-radius:10px;font-size:0.8rem;font-weight:600;color:var(--accent);\n  }\n  .city-tag .rm{cursor:pointer;opacity:.6;font-size:1rem;line-height:1;}\n  .city-tag .rm:hover{opacity:1;color:var(--red);}\n\n  /* ── MAIN SCROLL AREA ── */\n  .hub-body{flex:1;padding:20px 24px;display:flex;flex-direction:column;gap:20px;overflow-y:auto;}\n\n  /* ── STATES ── */\n  .empty-state{\n    display:flex;flex-direction:column;align-items:center;justify-content:center;\n    text-align:center;padding:60px 24px;gap:16px;color:var(--muted);\n  }\n  .empty-state svg{width:48px;height:48px;opacity:0.4;}\n  .empty-state h2{font-size:1.1rem;color:var(--subtle);}\n  .empty-state p{font-size:0.85rem;line-height:1.6;max-width:360px;}\n  .quick-picks{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:4px;}\n  .quick-pick{\n    padding:7px 14px;background:rgba(255,255,255,0.03);border:1px solid var(--border);\n    border-radius:10px;font-size:0.8rem;font-weight:500;color:var(--subtle);cursor:pointer;\n    transition:all .2s;\n  }\n  .quick-pick:hover{background:rgba(255,255,255,0.07);color:#fff;border-color:var(--border-hi);}\n\n  .loading-state{\n    display:flex;flex-direction:column;align-items:center;justify-content:center;\n    padding:48px;gap:14px;color:var(--subtle);\n  }\n  .spinner{width:40px;height:40px;border:3px solid rgba(255,255,255,.07);\n    border-top:3px solid var(--accent);border-radius:50%;animation:spin 1s linear infinite;}\n  @keyframes spin{to{transform:rotate(360deg);}}\n\n  /* ── ALERTS BANNER ── */\n  .alerts-banner{display:flex;flex-direction:column;gap:8px;}\n  .alert-card{\n    display:flex;gap:14px;padding:14px 18px;border-radius:14px;\n    border-left:4px solid var(--red);background:rgba(239,68,68,.06);\n    animation:slidein .3s ease;\n  }\n  .alert-card.warn{border-color:var(--amber);background:rgba(245,158,11,.06);}\n  .alert-card.info{border-color:var(--accent2);background:rgba(56,189,248,.06);}\n  @keyframes slidein{from{opacity:0;transform:translateY(-6px);}to{opacity:1;transform:translateY(0);}}\n  .alert-icon{font-size:1.5rem;flex-shrink:0;margin-top:2px;}\n  .alert-content h4{font-weight:700;font-size:0.9rem;margin-bottom:4px;}\n  .alert-content .alert-meta{font-size:0.75rem;color:var(--muted);margin-bottom:6px;}\n  .alert-content p{font-size:0.83rem;color:var(--subtle);line-height:1.5;}\n\n  /* ── CITY CARDS GRID ── */\n  .cities-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px;}\n  .city-card{\n    background:var(--panel);border:1px solid var(--border);border-radius:var(--r);\n    padding:22px;display:flex;flex-direction:column;gap:16px;\n    transition:border-color .2s,transform .2s,box-shadow .2s;\n    position:relative;overflow:hidden;\n  }\n  .city-card::before{\n    content:'';position:absolute;top:0;right:0;width:120px;height:120px;\n    background:radial-gradient(circle,rgba(99,102,241,.12) 0%,transparent 70%);\n    pointer-events:none;\n  }\n  .city-card:hover{border-color:var(--border-hi);transform:translateY(-2px);\n    box-shadow:0 12px 32px rgba(0,0,0,.3);}\n  .card-city-name{font-family:'Outfit',sans-serif;font-size:1.3rem;font-weight:700;}\n  .card-country{font-size:0.75rem;color:var(--muted);margin-top:2px;}\n  .card-temp-row{display:flex;align-items:center;gap:14px;margin:4px 0;}\n  .card-temp{font-family:'Outfit',sans-serif;font-size:3.5rem;font-weight:800;line-height:1;\n    background:linear-gradient(to bottom,#fff 40%,rgba(255,255,255,.5) 100%);\n    -webkit-background-clip:text;-webkit-text-fill-color:transparent;}\n  .card-icon{width:56px;height:56px;filter:drop-shadow(0 4px 8px rgba(0,0,0,.3));}\n  .card-condition{font-size:0.9rem;color:var(--subtle);font-weight:500;}\n  .card-stats{\n    display:grid;grid-template-columns:1fr 1fr;gap:10px;\n    padding-top:14px;border-top:1px solid var(--border);\n  }\n  .stat{display:flex;flex-direction:column;gap:3px;}\n  .stat-label{font-size:0.65rem;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);font-weight:600;}\n  .stat-val{font-size:0.9rem;font-weight:600;color:var(--text);}\n  .stat-bar{height:4px;border-radius:2px;background:rgba(255,255,255,.06);margin-top:4px;overflow:hidden;}\n  .stat-fill{height:100%;border-radius:2px;transition:width .6s ease;}\n\n  /* Rain badge */\n  .rain-badge{\n    display:inline-flex;align-items:center;gap:5px;padding:3px 10px;\n    border-radius:8px;font-size:0.75rem;font-weight:700;margin-top:4px;\n  }\n  .rain-low{background:rgba(34,197,94,.1);color:var(--green);border:1px solid rgba(34,197,94,.2);}\n  .rain-medium{background:rgba(245,158,11,.1);color:var(--amber);border:1px solid rgba(245,158,11,.2);}\n  .rain-high{background:rgba(239,68,68,.1);color:var(--red);border:1px solid rgba(239,68,68,.2);}\n\n  /* UV badge */\n  .uv-low{color:var(--green);}\n  .uv-mod{color:var(--amber);}\n  .uv-high{color:var(--red);}\n\n  /* ── 3-DAY FORECAST ── */\n  .forecast-strip{display:flex;gap:8px;overflow-x:auto;padding-bottom:2px;}\n  .fc-day{\n    flex:1;min-width:80px;background:rgba(255,255,255,.02);border:1px solid var(--border);\n    border-radius:12px;padding:10px;display:flex;flex-direction:column;align-items:center;gap:6px;\n    transition:background .2s;\n  }\n  .fc-day:hover{background:rgba(255,255,255,.05);}\n  .fc-day-name{font-size:0.7rem;font-weight:700;color:var(--muted);text-transform:uppercase;}\n  .fc-day img{width:32px;height:32px;}\n  .fc-hi{font-size:0.85rem;font-weight:700;}\n  .fc-lo{font-size:0.75rem;color:var(--muted);}\n  .fc-rain{font-size:0.7rem;color:var(--accent2);}\n\n  /* ── COMPARISON PANEL ── */\n  .comparison-panel{\n    background:var(--panel);border:1px solid var(--border);\n    border-radius:var(--r);padding:22px;\n  }\n  .section-title{\n    font-family:'Outfit',sans-serif;font-size:1.1rem;font-weight:700;\n    display:flex;align-items:center;gap:8px;margin-bottom:18px;\n  }\n  .section-title svg{width:18px;height:18px;color:var(--accent);}\n\n  /* Comparison Table */\n  .comp-table-wrap{overflow-x:auto;}\n  .comp-table{width:100%;border-collapse:collapse;font-size:0.83rem;}\n  .comp-table th{\n    padding:10px 14px;text-align:left;font-size:0.7rem;text-transform:uppercase;\n    letter-spacing:.7px;color:var(--muted);font-weight:700;\n    border-bottom:1px solid var(--border);white-space:nowrap;\n  }\n  .comp-table td{\n    padding:12px 14px;border-bottom:1px solid rgba(255,255,255,.03);\n    vertical-align:middle;white-space:nowrap;\n  }\n  .comp-table tr:last-child td{border-bottom:none;}\n  .comp-table .metric-col{color:var(--muted);font-weight:600;width:140px;}\n  .best{color:var(--green);font-weight:700;}\n  .worst{color:var(--red);font-weight:700;}\n\n  /* ── ANALYSIS BOX ── */\n  .analysis-box{\n    background:linear-gradient(135deg,rgba(99,102,241,.06) 0%,rgba(56,189,248,.04) 100%);\n    border:1px solid rgba(99,102,241,.15);border-radius:var(--r);padding:22px;\n  }\n  .analysis-box h3{font-family:'Outfit',sans-serif;font-size:1rem;font-weight:700;margin-bottom:14px;}\n  .analysis-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px;}\n  .analysis-item{display:flex;flex-direction:column;gap:6px;}\n  .analysis-item .ai-label{font-size:0.7rem;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);font-weight:700;}\n  .analysis-item .ai-winner{font-size:0.9rem;font-weight:700;color:#fff;}\n  .analysis-item .ai-note{font-size:0.78rem;color:var(--subtle);line-height:1.4;}\n  .verdict{\n    margin-top:16px;padding:14px 16px;border-radius:12px;\n    background:rgba(255,255,255,.03);border:1px solid var(--border);\n    font-size:0.85rem;color:var(--subtle);line-height:1.6;\n  }\n  .verdict strong{color:#fff;}\n\n  /* ── CHART ── */\n  .chart-panel{background:var(--panel);border:1px solid var(--border);border-radius:var(--r);padding:22px;}\n  #comp-chart{width:100%;height:280px;}\n\n  /* ── OVERALL SCORE BADGES ── */\n  .score-badge{\n    display:inline-flex;align-items:center;gap:6px;padding:4px 12px;\n    border-radius:20px;font-size:0.75rem;font-weight:700;\n  }\n  .score-great{background:rgba(34,197,94,.12);color:var(--green);border:1px solid rgba(34,197,94,.2);}\n  .score-good{background:rgba(99,102,241,.12);color:var(--accent);border:1px solid rgba(99,102,241,.2);}\n  .score-fair{background:rgba(245,158,11,.12);color:var(--amber);border:1px solid rgba(245,158,11,.2);}\n  .score-poor{background:rgba(239,68,68,.12);color:var(--red);border:1px solid rgba(239,68,68,.2);}\n</style>\n</head>\n<body>\n\n<!-- ══════════════════════════════════════════════════════════\n     HEADER + SEARCH\n═══════════════════════════════════════════════════════════════ -->\n<div class=\"hub-header\">\n  <div class=\"hub-brand\">\n    <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M3 15a4 4 0 004 4h9a5 5 0 10-4.584-7.003A4.5 4.5 0 103 15z\"/>\n    </svg>\n    <h1>SkyFlow Weather Hub</h1>\n  </div>\n  <div class=\"search-row\">\n    <div class=\"search-box\" id=\"search-box\">\n      <svg width=\"16\" height=\"16\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\" style=\"color:var(--muted);flex-shrink:0;margin-right:10px;\">\n        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M21 21l-4.35-4.35M17 11A6 6 0 105 11a6 6 0 0012 0z\"/>\n      </svg>\n      <input type=\"text\" id=\"city-input\" placeholder=\"Type a city name and press Enter…\" autocomplete=\"off\">\n    </div>\n    <button class=\"btn btn-primary\" onclick=\"addCityFromInput()\">\n      <svg width=\"14\" height=\"14\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2.5\">\n        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 4v16m8-8H4\"/>\n      </svg>\n      Add City\n    </button>\n    <button class=\"btn btn-danger\" onclick=\"clearAll()\">\n      <svg width=\"14\" height=\"14\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2.5\">\n        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M6 18L18 6M6 6l12 12\"/>\n      </svg>\n      Clear All\n    </button>\n  </div>\n  <div class=\"city-tags\" id=\"city-tags\"></div>\n</div>\n\n<!-- ══════════════════════════════════════════════════════════\n     BODY\n═══════════════════════════════════════════════════════════════ -->\n<div class=\"hub-body\" id=\"hub-body\">\n  <!-- Empty State -->\n  <div class=\"empty-state\" id=\"empty-state\">\n    <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"1.5\">\n      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M3 15a4 4 0 004 4h9a5 5 0 10-4.584-7.003A4.5 4.5 0 103 15z\"/>\n    </svg>\n    <h2>Your weather workspace is empty</h2>\n    <p>Search for cities above to see live weather data, forecasts, alerts, and multi-city comparisons.</p>\n    <div class=\"quick-picks\">\n      <div class=\"quick-pick\" onclick=\"quickAdd('Mumbai')\">Mumbai</div>\n      <div class=\"quick-pick\" onclick=\"quickAdd('London')\">London</div>\n      <div class=\"quick-pick\" onclick=\"quickAdd('New York')\">New York</div>\n      <div class=\"quick-pick\" onclick=\"quickAdd('Tokyo')\">Tokyo</div>\n      <div class=\"quick-pick\" onclick=\"quickAdd('Sydney')\">Sydney</div>\n      <div class=\"quick-pick\" onclick=\"quickAdd('Paris')\">Paris</div>\n      <div class=\"quick-pick\" onclick=\"quickAdd('Dubai')\">Dubai</div>\n      <div class=\"quick-pick\" onclick=\"quickAdd('Singapore')\">Singapore</div>\n    </div>\n  </div>\n</div>\n\n<script>\n// ══════════════════════════════════════════════════════════\n// STATE\n// ══════════════════════════════════════════════════════════\nconst API_BASE = 'http://localhost:8000';\nlet cityDataMap = {}; // city key → full API response\n\n// ══════════════════════════════════════════════════════════\n// INPUT HANDLING\n// ══════════════════════════════════════════════════════════\ndocument.getElementById('city-input').addEventListener('keydown', e => {\n  if (e.key === 'Enter') addCityFromInput();\n});\n\nfunction addCityFromInput() {\n  const input = document.getElementById('city-input');\n  const val = input.value.trim();\n  if (!val) return;\n  input.value = '';\n  loadCity(val);\n}\n\nfunction quickAdd(city) {\n  loadCity(city);\n}\n\nfunction clearAll() {\n  cityDataMap = {};\n  document.getElementById('city-tags').innerHTML = '';\n  render();\n}\n\n// ══════════════════════════════════════════════════════════\n// DATA FETCHING\n// ══════════════════════════════════════════════════════════\nasync function loadCity(cityQuery) {\n  const key = cityQuery.toLowerCase().trim();\n\n  // Don't reload same city\n  if (cityDataMap[key] !== undefined) {\n    showToast(`${cityQuery} is already loaded.`);\n    return;\n  }\n\n  // Placeholder while loading\n  cityDataMap[key] = null;\n  renderTags();\n  showBodyLoading();\n\n  try {\n    const res = await fetch(`${API_BASE}/forecast/${encodeURIComponent(cityQuery)}/3`);\n    if (!res.ok) {\n      const err = await res.json();\n      throw new Error(err?.error?.message || 'City not found');\n    }\n    const data = await res.json();\n    if (data.error) throw new Error(data.error.message);\n\n    // Store using resolved city name as key\n    const resolvedKey = data.location.name.toLowerCase();\n    // remove placeholder\n    delete cityDataMap[key];\n    cityDataMap[resolvedKey] = data;\n\n  } catch (err) {\n    delete cityDataMap[key];\n    showToast(`⚠️ ${err.message}`, true);\n  }\n\n  renderTags();\n  render();\n}\n\n// ══════════════════════════════════════════════════════════\n// RENDER TAGS\n// ══════════════════════════════════════════════════════════\nfunction renderTags() {\n  const container = document.getElementById('city-tags');\n  const keys = Object.keys(cityDataMap);\n  if (keys.length === 0) { container.innerHTML = ''; return; }\n\n  container.innerHTML = keys.map(k => {\n    const d = cityDataMap[k];\n    const label = d ? d.location.name : k;\n    const isLoading = d === null;\n    return `<div class=\"city-tag\">\n      ${isLoading ? '⏳' : '🌍'} ${label}\n      ${!isLoading ? `<span class=\"rm\" onclick=\"removeCity('${k}')\">×</span>` : ''}\n    </div>`;\n  }).join('');\n}\n\nfunction removeCity(key) {\n  delete cityDataMap[key];\n  renderTags();\n  render();\n}\n\n// ══════════════════════════════════════════════════════════\n// MAIN RENDER\n// ══════════════════════════════════════════════════════════\nfunction render() {\n  const body = document.getElementById('hub-body');\n  const loadedEntries = Object.entries(cityDataMap).filter(([, v]) => v !== null);\n\n  if (loadedEntries.length === 0) {\n    // Check if still loading\n    const loading = Object.values(cityDataMap).some(v => v === null);\n    if (loading) { showBodyLoading(); return; }\n    body.innerHTML = getEmptyStateHTML();\n    return;\n  }\n\n  const cities = loadedEntries.map(([, d]) => d);\n\n  let html = '';\n\n  // 1. ALERTS BANNER\n  const alertsHtml = buildAlertsSection(cities);\n  if (alertsHtml) html += alertsHtml;\n\n  // 2. CITY CARDS\n  html += `<div class=\"cities-grid\">`;\n  cities.forEach(d => { html += buildCityCard(d); });\n  html += `</div>`;\n\n  // 3. COMPARISON (only if 2+ cities)\n  if (cities.length >= 2) {\n    html += buildComparisonSection(cities);\n    html += buildAnalysisSection(cities);\n  }\n\n  body.innerHTML = html;\n\n  // Render Plotly chart after DOM insert\n  if (cities.length >= 2) {\n    renderComparisonChart(cities);\n  }\n}\n\n// ══════════════════════════════════════════════════════════\n// ALERTS SECTION\n// ══════════════════════════════════════════════════════════\nfunction buildAlertsSection(cities) {\n  const allAlerts = [];\n\n  cities.forEach(d => {\n    const cityName = d.location.name;\n    const cur = d.current;\n    const day = d.forecast.forecastday[0].day;\n    const apiAlerts = (d.alerts && d.alerts.alert) ? d.alerts.alert : [];\n\n    // Real API alerts\n    apiAlerts.forEach(a => {\n      allAlerts.push({\n        city: cityName,\n        type: 'danger',\n        emoji: '🚨',\n        title: a.headline || a.event || 'Weather Alert',\n        meta: `${cityName} · ${a.effective ? new Date(a.effective).toLocaleDateString() : 'Active'}`,\n        body: a.desc ? a.desc.slice(0, 280) + (a.desc.length > 280 ? '…' : '') : a.msg || 'See official sources for details.',\n      });\n    });\n\n    // Synthetic context-aware alerts\n    if (cur.uv >= 8) {\n      allAlerts.push({\n        city: cityName, type: 'danger', emoji: '☀️',\n        title: `Extreme UV Alert — ${cityName}`,\n        meta: `${cityName} · UV Index ${cur.uv}`,\n        body: `UV Index of ${cur.uv} (${getUvLevel(cur.uv)}) poses a significant risk of skin damage. Wear SPF 50+ sunscreen, protective clothing, and avoid outdoor exposure between 10 AM–4 PM. Children and fair-skinned individuals are especially vulnerable.`,\n      });\n    } else if (cur.uv >= 6) {\n      allAlerts.push({\n        city: cityName, type: 'warn', emoji: '🌤️',\n        title: `High UV Advisory — ${cityName}`,\n        meta: `${cityName} · UV Index ${cur.uv}`,\n        body: `UV Index of ${cur.uv} (High) requires precaution. Apply SPF 30+ sunscreen 20 minutes before sun exposure and reapply every 2 hours. Seek shade during peak hours.`,\n      });\n    }\n\n    if (day.daily_chance_of_rain >= 80) {\n      allAlerts.push({\n        city: cityName, type: 'danger', emoji: '🌧️',\n        title: `Heavy Rain Warning — ${cityName}`,\n        meta: `${cityName} · ${day.daily_chance_of_rain}% chance of rain`,\n        body: `Very high probability of significant rainfall today (${day.daily_chance_of_rain}%). Expect potential waterlogging, reduced road visibility, and transportation delays. Avoid low-lying areas and check for local flood advisories. Carry waterproof gear.`,\n      });\n    } else if (day.daily_chance_of_rain >= 60) {\n      allAlerts.push({\n        city: cityName, type: 'warn', emoji: '🌦️',\n        title: `Rain Advisory — ${cityName}`,\n        meta: `${cityName} · ${day.daily_chance_of_rain}% chance of rain`,\n        body: `Moderate-to-high chance of rain (${day.daily_chance_of_rain}%) expected. Carry an umbrella and be cautious of wet roads. Outdoor plans may need to be reconsidered.`,\n      });\n    }\n\n    if (cur.temp_c >= 40) {\n      allAlerts.push({\n        city: cityName, type: 'danger', emoji: '🥵',\n        title: `Extreme Heat Alert — ${cityName}`,\n        meta: `${cityName} · ${cur.temp_c}°C`,\n        body: `Temperatures of ${cur.temp_c}°C constitute a heat emergency. Risk of heat stroke and heat exhaustion is very high. Stay indoors in air-conditioned spaces, drink at least 3L of water daily, and check on elderly and vulnerable individuals frequently.`,\n      });\n    } else if (cur.temp_c >= 35) {\n      allAlerts.push({\n        city: cityName, type: 'warn', emoji: '🌡️',\n        title: `Heat Advisory — ${cityName}`,\n        meta: `${cityName} · ${cur.temp_c}°C`,\n        body: `High temperature of ${cur.temp_c}°C. Limit strenuous outdoor activities. Stay hydrated and wear light, breathable clothing. Never leave children or pets in parked vehicles.`,\n      });\n    }\n\n    if (cur.temp_c <= 0) {\n      allAlerts.push({\n        city: cityName, type: 'warn', emoji: '🥶',\n        title: `Freezing Temperatures — ${cityName}`,\n        meta: `${cityName} · ${cur.temp_c}°C`,\n        body: `Below-freezing temperature of ${cur.temp_c}°C. Risk of ice formation on roads and walkways. Dress in thermal layers and be extremely cautious of black ice while driving or walking.`,\n      });\n    }\n\n    if (cur.wind_kph >= 60) {\n      allAlerts.push({\n        city: cityName, type: 'danger', emoji: '💨',\n        title: `Strong Wind Warning — ${cityName}`,\n        meta: `${cityName} · ${cur.wind_kph} km/h winds`,\n        body: `Wind speeds of ${cur.wind_kph} km/h are dangerous. Risk of falling trees, damaged structures, and flying debris. Avoid driving in high-sided vehicles and stay away from exposed areas and coastal zones.`,\n      });\n    }\n\n    if (cur.humidity >= 90) {\n      allAlerts.push({\n        city: cityName, type: 'info', emoji: '💧',\n        title: `Very High Humidity — ${cityName}`,\n        meta: `${cityName} · ${cur.humidity}% humidity`,\n        body: `Relative humidity of ${cur.humidity}% makes the perceived temperature significantly higher than actual. Physical exertion should be minimised. Those with respiratory conditions should take extra precautions.`,\n      });\n    }\n\n    if (cur.vis_km < 2) {\n      allAlerts.push({\n        city: cityName, type: 'warn', emoji: '🌫️',\n        title: `Low Visibility Advisory — ${cityName}`,\n        meta: `${cityName} · ${cur.vis_km} km visibility`,\n        body: `Visibility reduced to ${cur.vis_km} km due to mist or fog. Motorists should use fog lights, reduce speed substantially, and maintain safe following distances. Airports may experience delays.`,\n      });\n    }\n  });\n\n  if (allAlerts.length === 0) {\n    return `<div class=\"alerts-banner\">\n      <div class=\"alert-card info\" style=\"border-left-color:var(--green);background:rgba(34,197,94,.06);\">\n        <div class=\"alert-icon\">✅</div>\n        <div class=\"alert-content\">\n          <h4>All Clear — No Active Alerts</h4>\n          <p>No significant weather hazards detected for the searched cities. Conditions are within normal ranges. Stay updated as conditions may change.</p>\n        </div>\n      </div>\n    </div>`;\n  }\n\n  return `<div class=\"alerts-banner\">${allAlerts.map(a => `\n    <div class=\"alert-card ${a.type === 'danger' ? '' : a.type}\">\n      <div class=\"alert-icon\">${a.emoji}</div>\n      <div class=\"alert-content\">\n        <h4>${a.title}</h4>\n        <div class=\"alert-meta\">${a.meta}</div>\n        <p>${a.body}</p>\n      </div>\n    </div>`).join('')}</div>`;\n}\n\n// ══════════════════════════════════════════════════════════\n// CITY CARD\n// ══════════════════════════════════════════════════════════\nfunction buildCityCard(d) {\n  const loc = d.location;\n  const cur = d.current;\n  const today = d.forecast.forecastday[0];\n  const day = today.day;\n\n  const rainChance = day.daily_chance_of_rain;\n  const rainClass = rainChance >= 70 ? 'rain-high' : rainChance >= 40 ? 'rain-medium' : 'rain-low';\n  const rainLabel = rainChance >= 70 ? '⛈ High Risk' : rainChance >= 40 ? '🌦 Moderate' : '☀️ Low Risk';\n  const uvClass = cur.uv >= 8 ? 'uv-high' : cur.uv >= 4 ? 'uv-mod' : 'uv-low';\n  const score = weatherScore(cur, day);\n  const scoreBadge = scoreHtml(score);\n\n  // 3-day strip\n  const fcStrip = d.forecast.forecastday.map(fd => {\n    const dayName = new Date(fd.date + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'short' });\n    return `<div class=\"fc-day\">\n      <div class=\"fc-day-name\">${dayName}</div>\n      <img src=\"${fd.day.condition.icon}\" alt=\"\">\n      <div class=\"fc-hi\">${Math.round(fd.day.maxtemp_c)}°</div>\n      <div class=\"fc-lo\">${Math.round(fd.day.mintemp_c)}°</div>\n      <div class=\"fc-rain\">💧 ${fd.day.daily_chance_of_rain}%</div>\n    </div>`;\n  }).join('');\n\n  return `<div class=\"city-card\">\n    <div>\n      <div style=\"display:flex;justify-content:space-between;align-items:flex-start;\">\n        <div>\n          <div class=\"card-city-name\">${loc.name}</div>\n          <div class=\"card-country\">${loc.country} · ${loc.localtime.split(' ')[1]}</div>\n        </div>\n        ${scoreBadge}\n      </div>\n      <div class=\"card-temp-row\">\n        <div class=\"card-temp\">${Math.round(cur.temp_c)}°</div>\n        <img class=\"card-icon\" src=\"${cur.condition.icon}\" alt=\"${cur.condition.text}\">\n      </div>\n      <div class=\"card-condition\">${cur.condition.text} · Feels like ${Math.round(cur.feelslike_c)}°C</div>\n    </div>\n\n    <div class=\"card-stats\">\n      <div class=\"stat\">\n        <span class=\"stat-label\">Humidity</span>\n        <span class=\"stat-val\">${cur.humidity}%</span>\n        <div class=\"stat-bar\"><div class=\"stat-fill\" style=\"width:${cur.humidity}%;background:var(--accent2);\"></div></div>\n      </div>\n      <div class=\"stat\">\n        <span class=\"stat-label\">Wind</span>\n        <span class=\"stat-val\">${Math.round(cur.wind_kph)} km/h ${cur.wind_dir}</span>\n        <div class=\"stat-bar\"><div class=\"stat-fill\" style=\"width:${Math.min(cur.wind_kph,100)}%;background:var(--accent);\"></div></div>\n      </div>\n      <div class=\"stat\">\n        <span class=\"stat-label\">Rain Prediction</span>\n        <span class=\"rain-badge ${rainClass}\">${rainLabel} (${rainChance}%)</span>\n      </div>\n      <div class=\"stat\">\n        <span class=\"stat-label\">UV Index</span>\n        <span class=\"stat-val ${uvClass}\"><strong>${cur.uv}</strong> — ${getUvLevel(cur.uv)}</span>\n      </div>\n      <div class=\"stat\">\n        <span class=\"stat-label\">Daily High / Low</span>\n        <span class=\"stat-val\">${Math.round(day.maxtemp_c)}° / ${Math.round(day.mintemp_c)}°</span>\n      </div>\n      <div class=\"stat\">\n        <span class=\"stat-label\">Visibility</span>\n        <span class=\"stat-val\">${cur.vis_km} km</span>\n      </div>\n    </div>\n\n    <div>\n      <div style=\"font-size:.7rem;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);font-weight:700;margin-bottom:8px;\">3-Day Forecast</div>\n      <div class=\"forecast-strip\">${fcStrip}</div>\n    </div>\n  </div>`;\n}\n\n// ══════════════════════════════════════════════════════════\n// COMPARISON TABLE\n// ══════════════════════════════════════════════════════════\nfunction buildComparisonSection(cities) {\n  const metrics = [\n    { label: '🌡️ Temperature', key: d => d.current.temp_c, fmt: v => `${v.toFixed(1)}°C`, best: 'neither' },\n    { label: '💧 Humidity', key: d => d.current.humidity, fmt: v => `${v}%`, best: 'low' },\n    { label: '🌧️ Rain Chance', key: d => d.forecast.forecastday[0].day.daily_chance_of_rain, fmt: v => `${v}%`, best: 'low' },\n    { label: '🔆 UV Index', key: d => d.current.uv, fmt: v => `${v}`, best: 'low' },\n    { label: '💨 Wind', key: d => d.current.wind_kph, fmt: v => `${Math.round(v)} km/h`, best: 'low' },\n    { label: '📊 Daily High', key: d => d.forecast.forecastday[0].day.maxtemp_c, fmt: v => `${v.toFixed(1)}°C`, best: 'neither' },\n    { label: '📉 Daily Low', key: d => d.forecast.forecastday[0].day.mintemp_c, fmt: v => `${v.toFixed(1)}°C`, best: 'neither' },\n    { label: '👁️ Visibility', key: d => d.current.vis_km, fmt: v => `${v} km`, best: 'high' },\n    { label: '⭐ Weather Score', key: d => weatherScore(d.current, d.forecast.forecastday[0].day), fmt: v => `${v}/100`, best: 'high' },\n  ];\n\n  const headers = `<th>Metric</th>` + cities.map(d => `<th>${d.location.name}</th>`).join('');\n\n  const rows = metrics.map(m => {\n    const vals = cities.map(d => m.key(d));\n    const maxVal = Math.max(...vals);\n    const minVal = Math.min(...vals);\n\n    const cells = cities.map((d, i) => {\n      const v = vals[i];\n      let cls = '';\n      if (m.best === 'high' && v === maxVal && vals.filter(x => x === maxVal).length < vals.length) cls = 'best';\n      if (m.best === 'low' && v === minVal && vals.filter(x => x === minVal).length < vals.length) cls = 'best';\n      if (m.best === 'high' && v === minVal && vals.filter(x => x === minVal).length < vals.length && vals.length > 1) cls = 'worst';\n      if (m.best === 'low' && v === maxVal && vals.filter(x => x === maxVal).length < vals.length && vals.length > 1) cls = 'worst';\n      return `<td class=\"${cls}\">${m.fmt(v)}</td>`;\n    }).join('');\n\n    return `<tr><td class=\"metric-col\">${m.label}</td>${cells}</tr>`;\n  }).join('');\n\n  return `<div class=\"comparison-panel\">\n    <div class=\"section-title\">\n      <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z\"/></svg>\n      City-to-City Comparison\n    </div>\n    <div class=\"comp-table-wrap\">\n      <table class=\"comp-table\">\n        <thead><tr>${headers}</tr></thead>\n        <tbody>${rows}</tbody>\n      </table>\n    </div>\n    <div style=\"font-size:0.72rem;color:var(--muted);margin-top:10px;display:flex;gap:16px;\">\n      <span style=\"color:var(--green);\">● Best value</span>\n      <span style=\"color:var(--red);\">● Needs attention</span>\n    </div>\n  </div>\n  <div class=\"chart-panel\">\n    <div class=\"section-title\">\n      <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z\"/></svg>\n      Comparative Weather Chart\n    </div>\n    <div id=\"comp-chart\"></div>\n  </div>`;\n}\n\n// ══════════════════════════════════════════════════════════\n// ANALYSIS SECTION\n// ══════════════════════════════════════════════════════════\nfunction buildAnalysisSection(cities) {\n  const scores = cities.map(d => ({ name: d.location.name, score: weatherScore(d.current, d.forecast.forecastday[0].day), data: d }));\n  scores.sort((a, b) => b.score - a.score);\n\n  const winner = scores[0];\n  const loser = scores[scores.length - 1];\n\n  // Warmest city\n  const warmest = [...cities].sort((a, b) => b.current.temp_c - a.current.temp_c)[0];\n  // Coolest city\n  const coolest = [...cities].sort((a, b) => a.current.temp_c - b.current.temp_c)[0];\n  // Driest\n  const driest = [...cities].sort((a, b) => a.forecast.forecastday[0].day.daily_chance_of_rain - b.forecast.forecastday[0].day.daily_chance_of_rain)[0];\n  // Wettest\n  const wettest = [...cities].sort((a, b) => b.forecast.forecastday[0].day.daily_chance_of_rain - a.forecast.forecastday[0].day.daily_chance_of_rain)[0];\n  // Clearest\n  const clearest = [...cities].sort((a, b) => b.current.vis_km - a.current.vis_km)[0];\n\n  // Overall verdict text\n  const tempRange = Math.max(...cities.map(d => d.current.temp_c)) - Math.min(...cities.map(d => d.current.temp_c));\n  const verdictParts = [];\n  if (tempRange > 15) verdictParts.push(`there is a dramatic <strong>${tempRange.toFixed(0)}°C temperature swing</strong> between cities`);\n  if (wettest.forecast.forecastday[0].day.daily_chance_of_rain >= 70) verdictParts.push(`<strong>${wettest.location.name}</strong> has severe rain risk and travel disruptions are likely`);\n  if (winner.data.current.uv < 3 && winner.score > 70) verdictParts.push(`<strong>${winner.name}</strong> offers the safest outdoor conditions overall`);\n\n  const verdict = `Overall, <strong>${winner.name}</strong> has the best weather conditions with a score of ${winner.score}/100, while <strong>${loser.name}</strong> presents the most challenging conditions at ${loser.score}/100. ${verdictParts.length ? 'Notably, ' + verdictParts.join(', and ') + '.' : ''}`;\n\n  return `<div class=\"analysis-box\">\n    <h3>📊 Overall Weather Intelligence</h3>\n    <div class=\"analysis-grid\">\n      <div class=\"analysis-item\">\n        <span class=\"ai-label\">🏆 Best Weather Conditions</span>\n        <span class=\"ai-winner\">${winner.name}</span>\n        <span class=\"ai-note\">Score ${winner.score}/100 — ${getScoreLabel(winner.score)} outdoor conditions</span>\n      </div>\n      <div class=\"analysis-item\">\n        <span class=\"ai-label\">🌡️ Warmest City</span>\n        <span class=\"ai-winner\">${warmest.location.name}</span>\n        <span class=\"ai-note\">${warmest.current.temp_c}°C · ${warmest.current.condition.text}</span>\n      </div>\n      <div class=\"analysis-item\">\n        <span class=\"ai-label\">❄️ Coolest City</span>\n        <span class=\"ai-winner\">${coolest.location.name}</span>\n        <span class=\"ai-note\">${coolest.current.temp_c}°C · ${coolest.current.condition.text}</span>\n      </div>\n      <div class=\"analysis-item\">\n        <span class=\"ai-label\">☀️ Driest / Best for Outdoor</span>\n        <span class=\"ai-winner\">${driest.location.name}</span>\n        <span class=\"ai-note\">Only ${driest.forecast.forecastday[0].day.daily_chance_of_rain}% rain probability</span>\n      </div>\n      <div class=\"analysis-item\">\n        <span class=\"ai-label\">🌧️ Highest Rain Risk</span>\n        <span class=\"ai-winner\">${wettest.location.name}</span>\n        <span class=\"ai-note\">${wettest.forecast.forecastday[0].day.daily_chance_of_rain}% chance — carry an umbrella!</span>\n      </div>\n      <div class=\"analysis-item\">\n        <span class=\"ai-label\">👁️ Clearest Visibility</span>\n        <span class=\"ai-winner\">${clearest.location.name}</span>\n        <span class=\"ai-note\">${clearest.current.vis_km} km — best for driving / flying</span>\n      </div>\n    </div>\n    <div class=\"verdict\">${verdict}</div>\n  </div>`;\n}\n\n// ══════════════════════════════════════════════════════════\n// PLOTLY CHART\n// ══════════════════════════════════════════════════════════\nfunction renderComparisonChart(cities) {\n  const el = document.getElementById('comp-chart');\n  if (!el || typeof Plotly === 'undefined') return;\n\n  const names = cities.map(d => d.location.name);\n  const colors = ['#6366f1','#38bdf8','#22c55e','#f59e0b','#ef4444','#a78bfa','#fb923c'];\n\n  const tracesTemp = {\n    x: names, y: cities.map(d => d.current.temp_c),\n    name: 'Temperature (°C)', type: 'bar',\n    marker: { color: colors.slice(0, names.length), opacity: 0.85 },\n    yaxis: 'y1',\n  };\n  const tracesRain = {\n    x: names, y: cities.map(d => d.forecast.forecastday[0].day.daily_chance_of_rain),\n    name: 'Rain Chance (%)', type: 'scatter', mode: 'lines+markers',\n    line: { color: '#38bdf8', width: 2 },\n    marker: { color: '#38bdf8', size: 8 },\n    yaxis: 'y2',\n  };\n  const tracesHumidity = {\n    x: names, y: cities.map(d => d.current.humidity),\n    name: 'Humidity (%)', type: 'scatter', mode: 'lines+markers',\n    line: { color: '#a78bfa', width: 2, dash: 'dash' },\n    marker: { color: '#a78bfa', size: 8 },\n    yaxis: 'y2',\n  };\n\n  const layout = {\n    barmode: 'group',\n    paper_bgcolor: 'rgba(0,0,0,0)', plot_bgcolor: 'rgba(0,0,0,0)',\n    font: { family: 'Inter, sans-serif', color: '#94a3b8', size: 11 },\n    margin: { t: 10, b: 40, l: 45, r: 55 },\n    legend: { orientation: 'h', x: 0, y: 1.06, font: { size: 11 } },\n    xaxis: { gridcolor: 'rgba(255,255,255,.04)', linecolor: 'rgba(255,255,255,.06)' },\n    yaxis: { title: '°C', gridcolor: 'rgba(255,255,255,.04)', linecolor: 'rgba(255,255,255,.04)', titlefont: { size: 11 } },\n    yaxis2: { title: '%', overlaying: 'y', side: 'right', gridcolor: 'transparent', linecolor: 'transparent', titlefont: { size: 11 }, range: [0, 110] },\n  };\n  Plotly.newPlot('comp-chart', [tracesTemp, tracesRain, tracesHumidity], layout, { responsive: true, displayModeBar: false });\n}\n\n// ══════════════════════════════════════════════════════════\n// HELPERS\n// ══════════════════════════════════════════════════════════\nfunction weatherScore(cur, day) {\n  let score = 100;\n  // Temperature extremes\n  if (cur.temp_c > 38) score -= 25;\n  else if (cur.temp_c > 32) score -= 12;\n  else if (cur.temp_c < 0) score -= 20;\n  else if (cur.temp_c < 5) score -= 10;\n  // Rain\n  score -= Math.round(day.daily_chance_of_rain * 0.3);\n  // UV\n  if (cur.uv >= 8) score -= 15;\n  else if (cur.uv >= 6) score -= 8;\n  // Humidity\n  if (cur.humidity >= 85) score -= 10;\n  else if (cur.humidity >= 70) score -= 5;\n  // Visibility\n  if (cur.vis_km < 2) score -= 10;\n  else if (cur.vis_km < 5) score -= 5;\n  // Wind\n  if (cur.wind_kph >= 60) score -= 15;\n  else if (cur.wind_kph >= 40) score -= 8;\n  return Math.max(0, Math.min(100, score));\n}\n\nfunction scoreHtml(score) {\n  if (score >= 75) return `<span class=\"score-badge score-great\">⭐ ${score}/100</span>`;\n  if (score >= 55) return `<span class=\"score-badge score-good\">✅ ${score}/100</span>`;\n  if (score >= 35) return `<span class=\"score-badge score-fair\">⚠️ ${score}/100</span>`;\n  return `<span class=\"score-badge score-poor\">🔴 ${score}/100</span>`;\n}\n\nfunction getScoreLabel(score) {\n  if (score >= 75) return 'excellent';\n  if (score >= 55) return 'good';\n  if (score >= 35) return 'fair';\n  return 'poor';\n}\n\nfunction getUvLevel(uv) {\n  if (uv <= 2) return 'Low';\n  if (uv <= 5) return 'Moderate';\n  if (uv <= 7) return 'High';\n  if (uv <= 10) return 'Very High';\n  return 'Extreme';\n}\n\nfunction showBodyLoading() {\n  document.getElementById('hub-body').innerHTML = `<div class=\"loading-state\"><div class=\"spinner\"></div><p>Fetching live weather data…</p></div>`;\n}\n\nfunction getEmptyStateHTML() {\n  return `<div class=\"empty-state\" id=\"empty-state\">\n    <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"1.5\">\n      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M3 15a4 4 0 004 4h9a5 5 0 10-4.584-7.003A4.5 4.5 0 103 15z\"/>\n    </svg>\n    <h2>Your weather workspace is empty</h2>\n    <p>Search for cities above to see live weather data, forecasts, alerts, and multi-city comparisons.</p>\n    <div class=\"quick-picks\">\n      <div class=\"quick-pick\" onclick=\"quickAdd('Mumbai')\">Mumbai</div>\n      <div class=\"quick-pick\" onclick=\"quickAdd('London')\">London</div>\n      <div class=\"quick-pick\" onclick=\"quickAdd('New York')\">New York</div>\n      <div class=\"quick-pick\" onclick=\"quickAdd('Tokyo')\">Tokyo</div>\n      <div class=\"quick-pick\" onclick=\"quickAdd('Sydney')\">Sydney</div>\n      <div class=\"quick-pick\" onclick=\"quickAdd('Paris')\">Paris</div>\n      <div class=\"quick-pick\" onclick=\"quickAdd('Dubai')\">Dubai</div>\n      <div class=\"quick-pick\" onclick=\"quickAdd('Singapore')\">Singapore</div>\n    </div>\n  </div>`;\n}\n\nlet _toastTimeout = null;\nfunction showToast(msg, isError = false) {\n  let toast = document.getElementById('_toast');\n  if (!toast) {\n    toast = document.createElement('div');\n    toast.id = '_toast';\n    toast.style.cssText = 'position:fixed;bottom:20px;left:50%;transform:translateX(-50%);padding:10px 20px;border-radius:12px;font-size:.85rem;font-weight:600;z-index:999;transition:opacity .3s;';\n    document.body.appendChild(toast);\n  }\n  toast.textContent = msg;\n  toast.style.background = isError ? 'rgba(239,68,68,.9)' : 'rgba(99,102,241,.9)';\n  toast.style.color = '#fff';\n  toast.style.opacity = '1';\n  clearTimeout(_toastTimeout);\n  _toastTimeout = setTimeout(() => { toast.style.opacity = '0'; }, 3000);\n}\n</script>\n</body>\n</html>\n"
