      "data": {
        "title": "Popular Cities Weather Centre",
        "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Popular Cities Weather Dashboard</title>\n    <!-- Google Fonts -->\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n    <!-- Plotly CDN (will be shimmed locally by Jetro) -->\n    <script src=\"https://cdn.plot.ly/plotly-latest.min.js\"></script>\n    <!-- CSS styles matching the dark-theme glassmorphism system -->\n    <style>\n        :root {\n            --bg-base: #070913;\n            --glass-bg: rgba(13, 17, 35, 0.65);\n            --glass-border: rgba(255, 255, 255, 0.08);\n            --accent: #6366f1;\n            --text-primary: #f8fafc;\n            --text-secondary: #cbd5e1;\n            --text-muted: #64748b;\n        }\n\n        body {\n            background-color: var(--bg-base);\n            color: var(--text-primary);\n            font-family: 'Inter', sans-serif;\n            margin: 0;\n            padding: 24px;\n            overflow-x: hidden;\n            display: flex;\n            flex-direction: column;\n            gap: 24px;\n            box-sizing: border-box;\n            min-height: 100vh;\n        }\n\n        /* Glass container */\n        .glass-panel {\n            background: var(--glass-bg);\n            border: 1px solid var(--glass-border);\n            backdrop-filter: blur(16px);\n            -webkit-backdrop-filter: blur(16px);\n            border-radius: 20px;\n            padding: 24px;\n            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);\n        }\n\n        header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            border-bottom: 1px solid rgba(255, 255, 255, 0.05);\n            padding-bottom: 16px;\n        }\n\n        h1 {\n            font-family: 'Outfit', sans-serif;\n            margin: 0;\n            font-size: 1.75rem;\n            font-weight: 700;\n            letter-spacing: -0.5px;\n            background: linear-gradient(135deg, #fff 40%, var(--accent) 100%);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n        }\n\n        .update-badge {\n            font-size: 0.8rem;\n            color: var(--text-muted);\n            font-weight: 500;\n            background: rgba(255, 255, 255, 0.04);\n            padding: 6px 12px;\n            border-radius: 10px;\n            border: 1px solid rgba(255, 255, 255, 0.03);\n        }\n\n        /* Grid for City Cards */\n        .city-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\n            gap: 20px;\n        }\n\n        .city-card {\n            background: rgba(255, 255, 255, 0.02);\n            border: 1px solid rgba(255, 255, 255, 0.04);\n            border-radius: 18px;\n            padding: 20px;\n            display: flex;\n            flex-direction: column;\n            gap: 12px;\n            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        .city-card:hover {\n            background: rgba(255, 255, 255, 0.05);\n            border-color: rgba(255, 255, 255, 0.12);\n            transform: translateY(-2px);\n            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);\n        }\n\n        .city-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: flex-start;\n        }\n\n        .city-title {\n            display: flex;\n            flex-direction: column;\n        }\n\n        .city-name {\n            font-family: 'Outfit', sans-serif;\n            font-weight: 700;\n            font-size: 1.25rem;\n            color: #fff;\n        }\n\n        .city-country {\n            font-size: 0.75rem;\n            color: var(--text-muted);\n        }\n\n        .city-icon {\n            width: 40px;\n            height: 40px;\n            filter: drop-shadow(0 4px 8px rgba(0,0,0,0.3));\n        }\n\n        .city-temp-row {\n            display: flex;\n            align-items: baseline;\n            gap: 8px;\n            margin: 8px 0;\n        }\n\n        .city-temp {\n            font-family: 'Outfit', sans-serif;\n            font-size: 2.5rem;\n            font-weight: 800;\n            line-height: 1;\n        }\n\n        .city-condition {\n            font-size: 0.85rem;\n            color: var(--text-secondary);\n            font-weight: 500;\n        }\n\n        .city-stats {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 12px;\n            padding-top: 12px;\n            border-top: 1px solid rgba(255, 255, 255, 0.05);\n            font-size: 0.75rem;\n        }\n\n        .stat-item {\n            display: flex;\n            flex-direction: column;\n            gap: 2px;\n        }\n\n        .stat-label {\n            color: var(--text-muted);\n            text-transform: uppercase;\n            font-size: 0.65rem;\n            letter-spacing: 0.5px;\n            font-weight: 600;\n        }\n\n        .stat-val {\n            font-weight: 600;\n            color: var(--text-secondary);\n        }\n\n        /* Chart section */\n        .chart-panel {\n            min-height: 350px;\n            width: 100%;\n        }\n\n        .chart-title {\n            font-family: 'Outfit', sans-serif;\n            font-size: 1.1rem;\n            font-weight: 600;\n            margin-top: 0;\n            margin-bottom: 16px;\n            color: #fff;\n        }\n\n        /* Error state */\n        .error-state {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            padding: 48px;\n            color: var(--text-muted);\n            gap: 12px;\n        }\n    </style>\n</head>\n<body>\n\n    <div class=\"glass-panel\">\n        <header>\n            <h1>Popular Cities Weather Centre</h1>\n            <span class=\"update-badge\" id=\"update-badge\">Updating telemetry...</span>\n        </header>\n\n        <div class=\"error-state\" id=\"empty-state\">\n            <p>Waiting for live weather telemetry to refresh...</p>\n        </div>\n\n        <div class=\"city-grid\" id=\"city-grid\" style=\"display: none;\">\n            <!-- City Cards will be dynamically injected here -->\n        </div>\n    </div>\n\n    <div class=\"glass-panel chart-panel\" id=\"chart-panel\" style=\"display: none;\">\n        <h2 class=\"chart-title\">Global Temperature Analytics</h2>\n        <div id=\"plotly-temp-chart\" style=\"width:100%; height:300px;\"></div>\n    </div>\n\n    <script>\n        // Listen for live update refresh events from Jetro\n        window.addEventListener(\"jet:refresh\", function(e) {\n            const data = e.detail;\n            if (!data || !data.cities || data.cities.length === 0) return;\n\n            // Hide empty state and show grid/charts\n            document.getElementById(\"empty-state\").style.display = \"none\";\n            document.getElementById(\"city-grid\").style.display = \"grid\";\n            document.getElementById(\"chart-panel\").style.display = \"block\";\n\n            // Update timestamp\n            document.getElementById(\"update-badge\").textContent = `Last update: ${data.updated_at}`;\n\n            // 1. Render City Cards\n            renderCityCards(data.cities);\n\n            // 2. Render Plotly Comparison Chart\n            renderPlotlyChart(data.cities);\n        });\n\n        function renderCityCards(cities) {\n            const container = document.getElementById(\"city-grid\");\n            container.innerHTML = \"\";\n\n            cities.forEach(city => {\n                const card = document.createElement(\"div\");\n                card.className = \"city-card\";\n                card.innerHTML = `\n                    <div class=\"city-header\">\n                        <div class=\"city-title\">\n                            <span class=\"city-name\">${city.name}</span>\n                            <span class=\"city-country\">${city.country}</span>\n                        </div>\n                        <img class=\"city-icon\" src=\"${city.icon}\" alt=\"${city.condition}\">\n                    </div>\n                    <div class=\"city-temp-row\">\n                        <span class=\"city-temp\">${Math.round(city.temp_c)}°C</span>\n                        <span class=\"city-condition\">${city.condition}</span>\n                    </div>\n                    <div class=\"city-stats\">\n                        <div class=\"stat-item\">\n                            <span class=\"stat-label\">Wind</span>\n                            <span class=\"stat-val\">${Math.round(city.wind_kph)} km/h ${city.wind_dir}</span>\n                        </div>\n                        <div class=\"stat-item\">\n                            <span class=\"stat-label\">Humidity</span>\n                            <span class=\"stat-val\">${city.humidity}%</span>\n                        </div>\n                        <div class=\"stat-item\">\n                            <span class=\"stat-label\">UV Index</span>\n                            <span class=\"stat-val\">${city.uv} (${getUvLabel(city.uv)})</span>\n                        </div>\n                        <div class=\"stat-item\">\n                            <span class=\"stat-label\">Daily Range</span>\n                            <span class=\"stat-val\">${Math.round(city.mintemp_c)}° - ${Math.round(city.maxtemp_c)}°</span>\n                        </div>\n                    </div>\n                `;\n                container.appendChild(card);\n            });\n        }\n\n        function renderPlotlyChart(cities) {\n            const names = cities.map(c => c.name);\n            const temps = cities.map(c => c.temp_c);\n            const minTemps = cities.map(c => c.mintemp_c);\n            const maxTemps = cities.map(c => c.maxtemp_c);\n\n            const traceCurrent = {\n                x: names,\n                y: temps,\n                name: 'Current Temperature',\n                type: 'bar',\n                marker: {\n                    color: '#6366f1',\n                    opacity: 0.8\n                }\n            };\n\n            const traceMin = {\n                x: names,\n                y: minTemps,\n                name: 'Min Forecasted',\n                type: 'bar',\n                marker: {\n                    color: '#38bdf8',\n                    opacity: 0.6\n                }\n            };\n\n            const traceMax = {\n                x: names,\n                y: maxTemps,\n                name: 'Max Forecasted',\n                type: 'bar',\n                marker: {\n                    color: '#facc15',\n                    opacity: 0.6\n                }\n            };\n\n            const data = [traceMin, traceCurrent, traceMax];\n\n            const layout = {\n                barmode: 'group',\n                paper_bgcolor: 'rgba(0,0,0,0)',\n                plot_bgcolor: 'rgba(0,0,0,0)',\n                font: {\n                    color: '#cbd5e1',\n                    family: 'Inter, sans-serif'\n                },\n                margin: { t: 40, b: 40, l: 40, r: 20 },\n                xaxis: {\n                    gridcolor: 'rgba(255, 255, 255, 0.05)',\n                    linecolor: 'rgba(255, 255, 255, 0.1)'\n                },\n                yaxis: {\n                    title: 'Temperature (°C)',\n                    gridcolor: 'rgba(255, 255, 255, 0.05)',\n                    linecolor: 'rgba(255, 255, 255, 0.1)'\n                },\n                legend: {\n                    orientation: 'h',\n                    x: 0,\n                    y: 1.15\n                }\n            };\n\n            const config = { responsive: true, displayModeBar: false };\n\n            Plotly.newPlot('plotly-temp-chart', data, layout, config);\n        }\n\n        function getUvLabel(uv) {\n            if (uv <= 2) return \"Low\";\n            if (uv <= 5) return \"Mod\";\n            if (uv <= 7) return \"High\";\n            return \"V. High\";\n        }\n    </script>\n</body>\n</html>\n",
        "_repaintKey": 1779522894444
      },
      "connections": []
    }
  ],
